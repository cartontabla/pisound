@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix mod:   <http://moddevices.com/ns/mod#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .

<http://pisound.org/plugins/amp>
    a lv2:Plugin, lv2:DynamicsPlugin ;

    doap:name "IA III Amp" ;

    doap:developer [
        foaf:name "Lino" ;
        foaf:mbox <mailto:lino.garcia@upm.es>
    ] ;

    doap:maintainer [
        foaf:name "Pisound" ;
        foaf:mbox <mailto:lino.garcia@upm.es>
    ] ;

    doap:license <https://www.gnu.org/licenses/gpl-3.0.en.html> ;

    mod:brand "Pisound" ;
    mod:label "IA III Amp" ;

    lv2:minorVersion 1 ;
    lv2:microVersion 0 ;

    rdfs:comment """
Un sencillo plugin de ganancia estéreo sin ruido de \"zipping\" al mover el parámetro de ganancia.
Modelado por Lino García Morales para el libro \"Procesamiento de Audio Digital en Tiempo Real\".
""" ;

    lv2:port
    [
        a lv2:InputPort, lv2:ControlPort ;
        lv2:index 0 ;
        lv2:symbol "gain" ;
        lv2:name "Gain" ;
        lv2:default 0.0 ;
        lv2:minimum -20.0 ;
        lv2:maximum 20.0 ;
        units:unit units:db ;
        lv2:scalePoint [ rdfs:label "Mute" ; rdf:value -60.0 ] ;
        lv2:scalePoint [ rdfs:label "0 dB" ; rdf:value 0.0 ]
    ] , [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 1 ;
        lv2:symbol "in_l" ;
        lv2:name "Input L"
    ] , [
        a lv2:InputPort, lv2:AudioPort ;
        lv2:index 2 ;
        lv2:symbol "in_r" ;
        lv2:name "Input R"
    ] , [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 3 ;
        lv2:symbol "out_l" ;
        lv2:name "Output L"
    ] , [
        a lv2:OutputPort, lv2:AudioPort ;
        lv2:index 4 ;
        lv2:symbol "out_r" ;
        lv2:name "Output R"
    ] .
