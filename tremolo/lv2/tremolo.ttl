@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
# --- Identidad del plugin (cambia el URI si quieres)
<http://example.org/lv2/tremolo>
a lv2:Plugin ;
doap:name "tremolo" ;
doap:license <https://spdx.org/licenses/MIT.html> ;
lv2:optionalFeature lv2:hardRTCapable ;
rdfs:comment "Simple stereo tremolo: y = x * g(t). StereoPhase offsets LEFT LFO only." ;
lv2:port
# --- Audio in
[ a lv2:InputPort , lv2:AudioPort ;
lv2:index 0 ;
lv2:symbol "in_l" ;
lv2:name "In L" ;
] ,
[ a lv2:InputPort , lv2:AudioPort ;
lv2:index 1 ;
lv2:symbol "in_r" ;
lv2:name "In R" ;
] ,
# --- Audio out
[ a lv2:OutputPort , lv2:AudioPort ;
lv2:index 2 ;
lv2:symbol "out_l" ;
lv2:name "Out L" ;
] ,
[ a lv2:OutputPort , lv2:AudioPort ;
lv2:index 3 ;
lv2:symbol "out_r" ;
lv2:name "Out R" ;
] ,
# --- Controls
[ a lv2:InputPort , lv2:ControlPort ;
lv2:index 4 ;
lv2:symbol "rate" ;
lv2:name "Rate (Hz)" ;
lv2:default 5.0 ;
lv2:minimum 0.05 ;
lv2:maximum 20.0 ;
] ,
[ a lv2:InputPort , lv2:ControlPort ;
lv2:index 5 ;
lv2:symbol "depth" ;
lv2:name "Depth" ;
lv2:default 0.8 ;
lv2:minimum 0.0 ;
lv2:maximum 1.0 ;
] ,
[ a lv2:InputPort , lv2:ControlPort ;
lv2:index 6 ;
lv2:symbol "stereo_phase" ;
lv2:name "StereoPhase (rad)" ;
lv2:default 0.0 ;
lv2:minimum 0.0 ;
lv2:maximum 6.283185307179586 ; # 2*pi
] ,
[ a lv2:InputPort , lv2:ControlPort ;
lv2:index 7 ;
lv2:symbol "wave_sel" ;
lv2:name "WaveSel" ;
lv2:default 1 ;
lv2:minimum 1 ;
lv2:maximum 10 ;
lv2:portProperty lv2:integer ;
lv2:scalePoint [ rdfs:label "Sine" ; rdf:value 1 ] ;
lv2:scalePoint [ rdfs:label "Square" ; rdf:value 2 ] ;
lv2:scalePoint [ rdfs:label "Triangle" ; rdf:value 3 ] ;
lv2:scalePoint [ rdfs:label "Saw Up" ; rdf:value 4 ] ;
lv2:scalePoint [ rdfs:label "Saw Down" ; rdf:value 5 ] ;
lv2:scalePoint [ rdfs:label "Custom 1" ; rdf:value 6 ] ;
lv2:scalePoint [ rdfs:label "Custom 2" ; rdf:value 7 ] ;
lv2:scalePoint [ rdfs:label "Custom 3" ; rdf:value 8 ] ;
lv2:scalePoint [ rdfs:label "Custom 4" ; rdf:value 9 ] ;
lv2:scalePoint [ rdfs:label "Custom 5" ; rdf:value 10 ] ;
] .